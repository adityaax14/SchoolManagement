{
	"info": {
		"_postman_id": "c1f7b889-1234-4a21-9961-d70a91e1d00d",
		"name": "School Management API",
		"description": "APIs for adding schools and retrieving a list of schools sorted by proximity to a user-specified location.",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "Add School",
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/json"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n    \"name\": \"Greenwood High\",\n    \"address\": \"123 Education Lane, Cityville\",\n    \"latitude\": 34.052235,\n    \"longitude\": -118.243683\n}"
				},
				"url": {
					"raw": "{{base_url}}/api/addSchool",
					"host": [
						"{{base_url}}"
					],
					"path": [
						"api",
						"addSchool"
					]
				},
				"description": "Adds a new school to the database."
			},
			"response": []
		},
		{
			"name": "List Schools",
			"request": {
				"method": "GET",
				"header": [],
				"url": {
					"raw": "{{base_url}}/api/listSchools?latitude=34.052235&longitude=-118.243683",
					"host": [
						"{{base_url}}"
					],
					"path": [
						"api",
						"listSchools"
					],
					"query": [
						{
							"key": "latitude",
							"value": "34.052235"
						},
						{
							"key": "longitude",
							"value": "-118.243683"
						}
					]
				},
				"description": "Fetches all schools sorted by proximity to the provided coordinates."
			},
			"response": []
		}
	],
	"variable": [
		{
			"key": "base_url",
			"value": "http://localhost:3000",
			"type": "string"
		}
	]
}
